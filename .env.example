# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/planflow
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/planflow_test

# Application
DEBUG=true
APP_NAME=PlanFlow

# Auth / JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookies
COOKIE_SECURE=false

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=planflow
