# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/planflow
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/planflow_test

# Application
DEBUG=true
APP_NAME=PlanFlow

# Auth / JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookies
COOKIE_SECURE=false

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# AI / OpenRouter
OPENROUTER_API_KEY=
AI_DEFAULT_MODEL=openai/gpt-5.2
AI_CONFIDENCE_THRESHOLD=0.3
AI_LLM_TIMEOUT=20
AI_MAX_RETRIES=3
AI_ENRICHMENT_CONCURRENCY=5

# AI Research (optional — enables web research during board generation)
# TAVILY_API_KEY=tvly-xxxxx
AI_MAX_RESEARCH_QUERIES=15
AI_MAX_FETCH_URLS=5
AI_RESEARCH_CONTEXT_MAX_CHARS=8000

# AI Memory (requires pgvector/pgvector:pg16 Docker image)
AI_MEMORY_ENABLED=true
AI_EMBEDDING_MODEL=openai/text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
AI_MEMORY_RETRIEVAL_LIMIT=15
AI_MEMORY_SIMILARITY_THRESHOLD=0.95

# PostgreSQL (used by Docker Compose — must use pgvector image for AI memory)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=planflow
